# Supabase (optional) — solange leer, nutzt die App localStorage.
# Trag deine Keys ein (Supabase Dashboard → Project Settings → API)
# und starte neu, dann speichert die App in der Cloud.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# KI-Coach (OpenAI) — NUR serverseitig, niemals NEXT_PUBLIC!
# Der Key bleibt auf dem Server (API-Route), kommt nie in den Browser.
OPENAI_API_KEY=
# Optional: Modell überschreiben (Standard: gpt-5, Fallback gpt-4o)
OPENAI_MODEL=

# Übungs-Videos (YouTube Data API v3) — optional, serverseitig.
# Ohne Key öffnet "Video ansehen" nur die YouTube-Suche. Mit Key läuft das
# Video inline. Key: Google Cloud Console → YouTube Data API v3 aktivieren.
YOUTUBE_API_KEY=
